<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg_primary">

    <!-- App Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_gallery"
        android:layout_width="match_parent"
        android:layout_height="?android:attr/actionBarSize"
        android:background="@color/bg_surface"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_screenshots"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tv_gallery_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Nessuno screenshot salvato.\nCatturali durante la riproduzione video."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Barra delle azioni di selezione -->
    <LinearLayout
        android:id="@+id/layout_selection_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:padding="8dp"
        android:gravity="center"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_select_all"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:text="Seleziona Tutti"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/accent_blue" />

        <Button
            android:id="@+id/btn_share_selected"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Condividi"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/accent_blue" />

        <Button
            android:id="@+id/btn_delete_selected"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Elimina"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/live_red" />

        <Button
            android:id="@+id/btn_cancel_selection"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:text="Annulla"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</LinearLayout>
